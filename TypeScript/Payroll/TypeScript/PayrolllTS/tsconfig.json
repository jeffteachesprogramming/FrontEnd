{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./js",

    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "types": [],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "skipLibCheck": true
  }
}